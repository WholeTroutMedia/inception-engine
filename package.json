{
  "name": "cle",
  "version": "5.1.16-COMMUNITY",
  "private": true,
  "description": "a generative reasoning engine",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @cle/genkit dev",
    "genkit:dev": "pnpm --filter @cle/genkit dev",
    "genkit:ui": "pnpm --filter @cle/genkit genkit:ui",
    "build": "pnpm --filter @cle/genkit build",
    "build:all": "pnpm -r run build",
    "type-check": "pnpm -r run type-check --filter \"./packages/*\" 2>/dev/null || true",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.2",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0"
  }
}