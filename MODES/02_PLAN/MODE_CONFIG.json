{
  "mode": "PLAN",
  "version": "4.0.0",
  "tagline": "Focused Execution Prep - Technical Specification",
  "objective": "TECHNICAL_SPECIFICATION",
  "description": "Detailed specification, architecture design, and task breakdown",

  "agent_roster": "project_specific",
