# Creative Liberation Engine — Environment Variables
# Copy this file to .env and fill in your keys.

# ─── Required for AI (at least one) ─────────────────────────────────────────
# Google AI Studio — free tier, good for development
GEMINI_API_KEY=your_gemini_api_key_here

# Or use Google Cloud (Vertex AI) for production
# GOOGLE_API_KEY=your_google_api_key
# GOOGLE_CLOUD_PROJECT=your-project-id

# ─── Optional providers ─────────────────────────────────────────────────────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# PERPLEXITY_API_KEY=
# DEEPSEEK_API_KEY=
# XAI_API_KEY=

# ─── Genkit server ─────────────────────────────────────────────────────────
PORT=4100
GENKIT_ENV=dev

# ─── Offline / local ───────────────────────────────────────────────────────
# Ollama runs locally — no key needed. Set host if not default.
# OLLAMA_HOST=http://127.0.0.1:11434

# ─── Optional services ─────────────────────────────────────────────────────
# ChromaDB for semantic memory (default: http://127.0.0.1:8000)
# CHROMADB_URL=http://127.0.0.1:8000
# CHROMADB_COLLECTION=cle_memory

# Dispatch server for DIRA metrics
# DISPATCH_URL=http://127.0.0.1:5050

# ─── Python engine (cle boot) ─────────────────────────────────────────────────
# CLE_DEFAULT_MODEL=gemini-2.5-flash
# CLE_ACCESS_TIER=studio
# CLE_HOST=0.0.0.0
# CLE_PORT=8080
# CLE_DEBUG=true
