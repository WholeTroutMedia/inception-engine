# Inception Engine - Environment Configuration
# Copy this file to .env and fill in your values
# HELIX DELTA: Performance Optimization additions marked with [HELIX]

# ==========================================
# AI PROVIDERS
# ==========================================

# Anthropic (Primary)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (Secondary)
OPENAI_API_KEY=your_openai_api_key_here

# Preferred provider (anthropic or openai)
AI_PROVIDER=anthropic

# ==========================================
# DATABASE
# ==========================================

# PostgreSQL (Long-term memory / Neocortex)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=inception_engine
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=inception_engine
POSTGRES_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# [HELIX] Async database pool settings
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20

# ==========================================
# CACHE
# ==========================================

# Redis (Working memory / Hippocampus)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# [HELIX] Redis pool settings
REDIS_POOL_MIN=5
REDIS_POOL_MAX=20
REDIS_CACHE_TTL=300

# ==========================================
# SYSTEM CONFIGURATION
# ==========================================

# Environment (development, staging, production)
ENVIRONMENT=development

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# [HELIX] Uvicorn workers (set to CPU count for production)
WORKERS=4

# ==========================================
# CELERY (Background Tasks)
# ==========================================

# Celery broker (Redis)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_CONCURRENCY=4

# ==========================================
# MONITORING
# ==========================================

# [HELIX] Sentry Error Tracking
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# [HELIX] OpenTelemetry Distributed Tracing
OTEL_EXPORTER_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=inception-engine
OTEL_ENABLED=false

# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_ENABLED=true
GRAFANA_PORT=3000
GRAFANA_PASSWORD=admin

# [HELIX] Structured Logging
LOG_FORMAT=json
LOG_CORRELATION_ID=true

# ==========================================
# CONSTITUTIONAL GUARD
# ==========================================

# Constitutional framework enforcement
CONSTITUTIONAL_ENFORCEMENT=strict

# Auto-block violations
AUTO_BLOCK_VIOLATIONS=true

# ==========================================
# GITHUB INTEGRATION
# ==========================================

# GitHub MCP (for repo operations)
GITHUB_TOKEN=your_github_token_here
GITHUB_ORG=WholeTroutMedia
GITHUB_REPO=inception-engine

# ==========================================
# DEPLOYMENT
# ==========================================

# Docker
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE=wholetroutmedia/inception-engine

# Kubernetes
K8S_NAMESPACE=inception-engine
K8S_CLUSTER=production

# ==========================================
# SECURITY
# ==========================================

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# API Keys
API_KEY_HEADER=X-API-Key

# [HELIX] CORS (comma-separated origins, tightened from *)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# [HELIX] Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ==========================================
# FEATURES
# ==========================================

# Enable experimental features
ENABLE_EXPERIMENTAL=false

# Enable debug mode
DEBUG=false

# Enable telemetry
ENABLE_TELEMETRY=true

# [HELIX] Performance mode (enables uvloop, orjson)
PERFORMANCE_MODE=true
