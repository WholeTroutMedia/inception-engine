{
    "radius": {
        "none": {
            "$value": "0px",
            "$type": "dimension"
        },
        "sm": {
            "$value": "4px",
            "$type": "dimension"
        },
        "md": {
            "$value": "8px",
            "$type": "dimension"
        },
        "lg": {
            "$value": "16px",
            "$type": "dimension"
        },
        "xl": {
            "$value": "24px",
            "$type": "dimension"
        },
        "2xl": {
            "$value": "32px",
            "$type": "dimension"
        },
        "full": {
            "$value": "9999px",
            "$type": "dimension"
        }
    },
    "shadow": {
        "none": {
            "$value": "none",
            "$type": "shadow"
        },
        "xs": {
            "$value": "0 1px 1px 0 rgba(0,0,0,0.05)",
            "$type": "shadow"
        },
        "sm": {
            "$value": "0 1px 2px 0 rgba(0,0,0,0.08)",
            "$type": "shadow"
        },
        "md": {
            "$value": "0 4px 6px -1px rgba(0,0,0,0.10), 0 2px 4px -2px rgba(0,0,0,0.10)",
            "$type": "shadow"
        },
        "lg": {
            "$value": "0 10px 15px -3px rgba(0,0,0,0.10), 0 4px 6px -4px rgba(0,0,0,0.10)",
            "$type": "shadow"
        },
        "xl": {
            "$value": "0 20px 25px -5px rgba(0,0,0,0.10), 0 8px 10px -6px rgba(0,0,0,0.10)",
            "$type": "shadow"
        },
        "2xl": {
            "$value": "0 25px 50px -12px rgba(0,0,0,0.25)",
            "$type": "shadow"
        },
        "inner": {
            "$value": "inset 0 2px 4px 0 rgba(0,0,0,0.06)",
            "$type": "shadow"
        },
        "glow": {
            "$value": "0 0 20px rgba(15,98,254,0.35)",
            "$type": "shadow",
            "$description": "Brand blue glow — used on active/focused key surfaces"
        },
        "glowWarm": {
            "$value": "0 0 20px rgba(201,123,28,0.35)",
            "$type": "shadow",
            "$description": "Warm amber glow — used on highlight/featured surfaces"
        }
    }
}