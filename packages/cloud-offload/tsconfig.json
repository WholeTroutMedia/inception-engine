{
    "include":  [
                    "src/**/*"
                ],
    "compilerOptions":  {
                            "forceConsistentCasingInFileNames":  true,
                            "outDir":  "./dist",
                            "moduleResolution":  "NodeNext",
                            "strict":  true,
                            "target":  "ES2022",
                            "esModuleInterop":  true,
                            "skipLibCheck":  true,
                            "module":  "NodeNext",
                            "rootDir":  "./src"
                        }
}
