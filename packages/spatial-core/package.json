{
    "name": "@spatial/core",
    "version": "0.1.0",
    "description": "Physics-native, context-aware spatial web framework. WebGPU + Rapier WASM + ORACLE context signals.",
    "author": "The Operator <justin@wholetoutmedia.com>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Creative Liberation Engine Community/spatial-core"
    },
    "keywords": [
        "spatial-web",
        "webgpu",
        "physics",
        "rapier",
        "3d",
        "oracle",
        "context-aware",
        "interactive",
        "web",
        "typescript"
    ],
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./react": {
            "types": "./dist/react/index.d.ts",
            "import": "./dist/react/index.js",
            "require": "./dist/react/index.cjs"
        },
        "./physics": {
            "types": "./dist/physics/index.d.ts",
            "import": "./dist/physics/index.js",
            "require": "./dist/physics/index.cjs"
        },
        "./oracle": {
            "types": "./dist/oracle/index.d.ts",
            "import": "./dist/oracle/index.js",
            "require": "./dist/oracle/index.cjs"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsup src/index.ts src/react/index.ts src/physics/index.ts src/oracle/index.ts --format esm,cjs --dts --clean",
        "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src --ext .ts,.tsx",
        "test": "echo \"No tests defined\"",
        "test:watch": "vitest",
        "prepublishOnly": "pnpm run build"
    },
    "dependencies": {
        "@dimforge/rapier3d-compat": "^0.12.0",
        "three": "^0.169.0"
    },
    "peerDependencies": {
        "react": ">=18.0.0",
        "react-dom": ">=18.0.0"
    },
    "peerDependenciesMeta": {
        "react": {
            "optional": true
        },
        "react-dom": {
            "optional": true
        }
    },
    "devDependencies": {
        "@types/three": "^0.169.0",
        "@types/react": "^18.0.0",
        "tsup": "^8.0.0",
        "typescript": "^5.3.0",
        "vitest": "^1.0.0"
    },
    "sideEffects": false
}
