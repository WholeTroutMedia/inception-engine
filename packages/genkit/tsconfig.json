{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": "src",
        "composite": true,
        "incremental": true,
        "tsBuildInfoFile": ".tsbuildinfo",
        "declarationDir": "dist",
        "sourceMap": false,
        "declarationMap": false
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.tsx"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}