    "devDependencies": {
        "@types/node": "^20.11.16",
        "@types/node-hid": "^1.3.4",
        "@types/ws": "^8.5.10",
        "@vitest/coverage-v8": "^1.6.1",
        "tsx": "^4.7.0",
        "typescript": "^5.3.3",
        "vitest": "^4.0.18"
    }
}