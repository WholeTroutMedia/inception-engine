{
    "name": "@inception/mcp-router",
    "version": "5.0.0",
    "private": true,
    "description": "Creative Liberation Engine — Dynamic MCP Server Autoloader and Intent-Based Router",
    "type": "module",
    "bin": {
        "mcp-router": "./dist/mcp-server.js"
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "tsc -b",
        "dev": "tsx --watch src/index.ts",
        "test": "vitest run",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.27.1",
        "@types/pg": "^8.18.0",
        "express": "^5.2.1",
        "google-auth-library": "^10.6.1",
        "pg": "^8.20.0",
        "redis": "^5.11.0",
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/node": "^22.0.0",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0",
        "vitest": "^3.0.0"
    }
}