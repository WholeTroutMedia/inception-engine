{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://creative-liberation-engine.local/schemas/ui/Heading.json",
    "title": "Heading",
    "description": "Semantic typography component mapped to heading scale tokens.",
    "type": "object",
    "properties": {
        "level": {
            "type": "number",
            "enum": [
                1,
                2,
                3,
                4,
                5,
                6
            ],
            "default": 1,
            "description": "Semantic heading level (h1-h6)."
        },
        "variant": {
            "type": "string",
            "enum": [
                "display",
                "heading",
                "subheading"
            ],
            "default": "heading",
            "description": "Visual scale variant for typography tracking and weight mappings."
        },
        "color": {
            "type": "string",
            "enum": [
                "default",
                "primary",
                "secondary",
                "muted",
                "accent"
            ],
            "default": "default",
            "description": "Semantic text color mapped to token system."
        },
        "align": {
            "type": "string",
            "enum": [
                "left",
                "center",
                "right"
            ],
            "default": "left",
            "description": "Text alignment override."
        }
    },
    "additionalProperties": false,
    "required": [
        "level"
    ]
}